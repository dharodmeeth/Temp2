/* ----------------------------------------------------
   7) External resource pools / workload groups (if any)
   ---------------------------------------------------- */
IF OBJECT_ID('sys.resource_governor_external_resource_pools') IS NOT NULL
BEGIN
    SELECT
        erp.external_pool_id,
        [External Pool]         = erp.name,
        erp.min_cpu_percent,
        erp.max_cpu_percent,
        erp.cap_cpu_percent,
        erp.min_memory_percent,
        erp.max_memory_percent
    FROM sys.resource_governor_external_resource_pools AS erp
    ORDER BY erp.external_pool_id;

    PRINT REPLICATE('-', 90);

    IF OBJECT_ID('sys.dm_resource_governor_external_resource_pools') IS NOT NULL
    BEGIN
        SELECT
            derp.external_pool_id,
            [External Pool]     = erp.name,
            derp.total_memory_kb,
            derp.used_memory_kb,
            derp.target_memory_kb
        FROM sys.dm_resource_governor_external_resource_pools AS derp
        JOIN sys.resource_governor_external_resource_pools AS erp
          ON derp.external_pool_id = erp.external_pool_id
        ORDER BY derp.external_pool_id;
    END
END
ELSE
BEGIN
    PRINT 'No external resource pools present on this instance.';
END
