SET NOCOUNT ON;
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;

DECLARE @instance sysname       = @@SERVERNAME;
DECLARE @version  nvarchar(128) = CAST(SERVERPROPERTY('ProductVersion') AS nvarchar(128));
DECLARE @edition  nvarchar(128) = CAST(SERVERPROPERTY('Edition') AS nvarchar(128));
DECLARE @engine   nvarchar(128) = CAST(SERVERPROPERTY('EngineEdition') AS nvarchar(128));

DECLARE @max_server_memory_mb bigint;

SELECT @max_server_memory_mb = TRY_CAST(value_in_use AS bigint)
FROM sys.configurations
WHERE name = 'max server memory (MB)';

PRINT REPLICATE('=', 90);
PRINT '1) Instance / Resource Governor status';
PRINT REPLICATE('=', 90);

SELECT
    [Report Time (UTC)] = CONVERT(datetime2(0), SYSUTCDATETIME()),
    [Instance]          = @instance,
    [Product Version]   = @version,
    [Edition]           = @edition,
    [EngineEdition]     = @engine,
    [RG Enabled?]       = CASE is_enabled WHEN 1 THEN 'YES' ELSE 'NO' END,
    [Classifier Function] =
        COALESCE(
            QUOTENAME(OBJECT_SCHEMA_NAME(classifier_function_id)) + '.' +
            QUOTENAME(OBJECT_NAME(classifier_function_id)),
            '<none>'
        )
FROM sys.resource_governor_configuration;

PRINT REPLICATE('-', 90);
PRINT '2) Classifier function definition';
PRINT REPLICATE('-', 90);

DECLARE @classifier_id int;

SELECT @classifier_id = classifier_function_id
FROM sys.resource_governor_configuration;

IF @classifier_id IS NOT NULL
BEGIN
    SELECT
        [Classifier Function] = QUOTENAME(OBJECT_SCHEMA_NAME(@classifier_id)) + '.' + QUOTENAME(OBJECT_NAME(@classifier_id)),
        [Created Date]        = OBJECTPROPERTYEX(@classifier_id, 'CreationDate'),
        [Is Schema Bound?]    = CASE WHEN OBJECTPROPERTYEX(@classifier_id, 'IsSchemaBound') = 1 THEN 'YES' ELSE 'NO' END,
        [Definition]          = OBJECT_DEFINITION(@classifier_id);
END
ELSE
BEGIN
    SELECT
        [Classifier Function] = '<none configured>',
        [Created Date] = NULL,
        [Is Schema Bound?] = NULL,
        [Definition] = NULL;
END

PRINT REPLICATE('-', 90);
PRINT '3) Resource pools';
PRINT REPLICATE('-', 90);

IF OBJECT_ID('tempdb..#resource_pools') IS NOT NULL
    DROP TABLE #resource_pools;

CREATE TABLE #resource_pools
(
    pool_id int,
    name sysname,
    min_cpu_percent int NULL,
    max_cpu_percent int NULL,
    cap_cpu_percent int NULL,
    min_memory_percent int NULL,
    max_memory_percent int NULL,
    min_iops_per_volume int NULL,
    max_iops_per_volume int NULL
);

DECLARE @sql_pools nvarchar(max) = N'
INSERT INTO #resource_pools
(
    pool_id,
    name,
    min_cpu_percent,
    max_cpu_percent,
    cap_cpu_percent,
    min_memory_percent,
    max_memory_percent,
    min_iops_per_volume,
    max_iops_per_volume
)
SELECT
    pool_id,
    name,
    min_cpu_percent,
    max_cpu_percent,
    ' + CASE WHEN COL_LENGTH('sys.resource_governor_resource_pools', 'cap_cpu_percent') IS NOT NULL
             THEN 'cap_cpu_percent'
             ELSE 'CAST(NULL AS int)' END + N',
    min_memory_percent,
    max_memory_percent,
    ' + CASE WHEN COL_LENGTH('sys.resource_governor_resource_pools', 'min_iops_per_volume') IS NOT NULL
             THEN 'min_iops_per_volume'
             ELSE 'CAST(NULL AS int)' END + N',
    ' + CASE WHEN COL_LENGTH('sys.resource_governor_resource_pools', 'max_iops_per_volume') IS NOT NULL
             THEN 'max_iops_per_volume'
             ELSE 'CAST(NULL AS int)' END + N'
FROM sys.resource_governor_resource_pools;
';

EXEC sys.sp_executesql @sql_pools;

SELECT
    pool_id,
    [Pool Name]        = name,
    [Min CPU %]        = min_cpu_percent,
    [Max CPU %]        = max_cpu_percent,
    [Cap CPU %]        = cap_cpu_percent,
    [Min Mem %]        = min_memory_percent,
    [Max Mem %]        = max_memory_percent,
    [Min Mem (MB est)] = CASE
                            WHEN @max_server_memory_mb IS NOT NULL AND min_memory_percent IS NOT NULL
                            THEN (@max_server_memory_mb * min_memory_percent) / 100
                            ELSE NULL
                         END,
    [Max Mem (MB est)] = CASE
                            WHEN @max_server_memory_mb IS NOT NULL AND max_memory_percent IS NOT NULL
                            THEN (@max_server_memory_mb * max_memory_percent) / 100
                            ELSE NULL
                         END,
    [Min IOPS/Vol]     = min_iops_per_volume,
    [Max IOPS/Vol]     = max_iops_per_volume
FROM #resource_pools
ORDER BY pool_id;

PRINT REPLICATE('-', 90);
PRINT '4) Workload groups';
PRINT REPLICATE('-', 90);

SELECT
    wg.group_id,
    [Workload Group]                  = wg.name,
    [Parent Pool]                     = rp.name,
    [Importance]                      = wg.importance,
    [Request Max Mem Grant %]         = wg.request_max_memory_grant_percent,
    [Request Max CPU Time (sec)]      = wg.request_max_cpu_time_sec,
    [Request Mem Grant Timeout (sec)] = wg.request_memory_grant_timeout_sec,
    [Max DOP]                         = wg.max_dop,
    [Group Max Requests]              = wg.group_max_requests
FROM sys.resource_governor_workload_groups AS wg
JOIN sys.resource_governor_resource_pools AS rp
    ON wg.pool_id = rp.pool_id
ORDER BY rp.name, wg.name;

PRINT REPLICATE('-', 90);
PRINT '5) Runtime pool stats';
PRINT REPLICATE('-', 90);

IF HAS_PERMS_BY_NAME(NULL, NULL, 'VIEW SERVER STATE') = 1
BEGIN
    SELECT
        rpr.pool_id,
        [Pool Name]          = rp.name,
        rpr.min_cpu_percent,
        rpr.max_cpu_percent,
        rpr.min_memory_percent,
        rpr.max_memory_percent,
        [Total Mem KB]       = rpr.total_memory_kb,
        [Used Mem KB]        = rpr.used_memory_kb,
        [Target Mem KB]      = rpr.target_memory_kb,
        [Blocked Mem Grants] = rpr.blocked_process_count
    FROM sys.dm_resource_governor_resource_pools AS rpr
    JOIN sys.resource_governor_resource_pools AS rp
        ON rpr.pool_id = rp.pool_id
    ORDER BY rpr.pool_id;

    PRINT REPLICATE('-', 90);
    PRINT '6) Runtime workload group stats';
    PRINT REPLICATE('-', 90);

    SELECT
        rwg.group_id,
        [Workload Group]                 = wg.name,
        [Parent Pool]                    = rp.name,
        rwg.total_request_count,
        rwg.active_request_count,
        rwg.queued_request_count,
        rwg.total_cpu_limit_violation_count,
        rwg.total_cpu_violation_count,
        rwg.total_lock_wait_count,
        rwg.total_memory_kb,
        rwg.used_memory_kb,
        rwg.request_max_memory_grant_percent
    FROM sys.dm_resource_governor_workload_groups AS rwg
    JOIN sys.resource_governor_workload_groups AS wg
        ON rwg.group_id = wg.group_id
    JOIN sys.resource_governor_resource_pools AS rp
        ON wg.pool_id = rp.pool_id
    ORDER BY rp.name, wg.name;
END
ELSE
BEGIN
    PRINT 'Note: DMV sections skipped because VIEW SERVER STATE permission is not present.';
END

PRINT REPLICATE('-', 90);
PRINT '7) External resource pools';
PRINT REPLICATE('-', 90);

IF OBJECT_ID('sys.resource_governor_external_resource_pools') IS NOT NULL
BEGIN
    SELECT
        external_pool_id,
        [External Pool] = name,
        min_cpu_percent,
        max_cpu_percent,
        CASE
            WHEN COL_LENGTH('sys.resource_governor_external_resource_pools', 'cap_cpu_percent') IS NOT NULL
            THEN cap_cpu_percent
            ELSE NULL
        END AS [Cap CPU %],
        min_memory_percent,
        max_memory_percent
    FROM sys.resource_governor_external_resource_pools
    ORDER BY external_pool_id;

    IF OBJECT_ID('sys.dm_resource_governor_external_resource_pools') IS NOT NULL
    BEGIN
        PRINT REPLICATE('-', 90);
        PRINT '8) External resource pool runtime stats';
        PRINT REPLICATE('-', 90);

        SELECT
            derp.external_pool_id,
            [External Pool] = erp.name,
            derp.total_memory_kb,
            derp.used_memory_kb,
            derp.target_memory_kb
        FROM sys.dm_resource_governor_external_resource_pools AS derp
        JOIN sys.resource_governor_external_resource_pools AS erp
            ON derp.external_pool_id = erp.external_pool_id
        ORDER BY derp.external_pool_id;
    END
END
ELSE
BEGIN
    PRINT 'No external resource pools present on this instance.';
END

DROP TABLE IF EXISTS #resource_pools;
PRINT REPLICATE('=', 90);
